  "devDependencies": {
    "@types/node":   "^22.0.0",
    "@types/pg":     "^8.11.0",
    "typescript":    "^5.6.0",
    "ts-node":       "^10.9.2",
    "jest":          "^29.7.0",
    "ts-jest":       "^29.2.0",
    "@types/jest":   "^29.5.0"
